# Source files (bundled by esbuild)
.vscode/**
.vscode-test/**
src/**
webview-ui/**

# Include feature config files loaded at runtime via fs (not bundled by esbuild)
!src/features/*/config/**/*.json
!src/core/*/config/**/*.json

# Dependencies (bundled by esbuild)
node_modules/**

# Development tool caches — never part of the extension
.serena/**
.playwright-mcp/**

# TypeScript-compiled individual JS files are redundant: esbuild bundles
# everything into dist/extension.js. Only the esbuild outputs are needed.
dist/commands/**
dist/core/**
dist/features/**
dist/types/**
dist/utils/**

# Source maps (development only)
dist/**/*.map

# Build / tooling config
.gitignore
.eslintrc.json
tsconfig.json
tsconfig.build.json
tsconfig.webview.json
webpack.config.js
esbuild.config.js
eslint.config.mjs
.prettierignore
.swcrc
jest.config.js
package.json.backup
package-lock.json

# Development files
**/*.ts
**/.git/**
.github/**
test/**
tests/**
docs/**
coverage/**
report/**
.rptc/**
.claude/**

# Scripts (except required ones)
scripts/keys.json

# Documentation (keep README and CHANGELOG)
*.md
!README.md
!CHANGELOG.md
