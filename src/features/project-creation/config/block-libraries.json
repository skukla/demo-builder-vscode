{
  "$schema": "./block-libraries.schema.json",
  "version": "1.0.0",
  "libraries": [
    {
      "id": "demo-team-blocks",
      "name": "Demo Team Block Collection",
      "description": "General-purpose blocks built by the Demo Team, usable in any EDS storefront",
      "type": "storefront",
      "source": {
        "owner": "skukla",
        "repo": "citisignal-eds-boilerplate",
        "branch": "main"
      },
      "nativeForPackages": ["citisignal"],
      "stackTypes": ["eds-storefront"]
    },
    {
      "id": "isle5",
      "name": "Isle5 Block Collection",
      "description": "Custom EDS blocks: hero, carousel, newsletter, store locator, and more",
      "type": "standalone",
      "source": {
        "owner": "skukla",
        "repo": "isle5",
        "branch": "main"
      },
      "stackTypes": ["eds-storefront"],
      "default": true
    },
    {
      "id": "buildright-blocks",
      "name": "BuildRight Blocks",
      "description": "Branded blocks from the BuildRight EDS storefront",
      "type": "storefront",
      "source": {
        "owner": "skukla",
        "repo": "buildright-eds",
        "branch": "main"
      },
      "nativeForPackages": ["buildright"],
      "onlyForPackages": ["buildright"],
      "stackTypes": ["eds-storefront"]
    }
  ]
}
