{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Demo Builder Deployables Catalog Schema",
  "description": "Schema for the declarative catalog of pre-built deployables (meshes and integrations)",
  "type": "object",
  "required": ["version", "deployables"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Schema version (e.g., '1.0.0')"
    },
    "deployables": {
      "type": "array",
      "description": "Array of deployable catalog entries (the three seeded meshes, plus integrations over time)",
      "items": {
        "$ref": "#/definitions/deployable"
      },
      "minItems": 1
    }
  },
  "definitions": {
    "deployable": {
      "type": "object",
      "required": ["id", "name", "description", "kind", "source"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "description": "Unique identifier (lowercase, hyphen-separated)"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Display name"
        },
        "description": {
          "type": "string",
          "description": "What the deployable provides"
        },
        "kind": {
          "type": "string",
          "enum": ["mesh", "integration"],
          "description": "Deployable kind"
        },
        "source": {
          "$ref": "#/definitions/gitHubSource"
        },
        "compatibleBackends": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Backend ids this deployable fits (omitted = any backend)"
        },
        "compatibleFrontends": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Frontend ids this deployable fits (omitted = any frontend)"
        },
        "requiredApis": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Adobe API sdkCodes/names to subscribe on the workspace (e.g. GraphQLServiceSDK)"
        },
        "providesEnvVars": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Env-var names this deployable provides to consumers (e.g. MESH_ENDPOINT)"
        },
        "envSchema": {
          "type": "array",
          "description": "The deployable's own env-var schema (inputs it needs)",
          "items": {
            "$ref": "#/definitions/envVar"
          }
        }
      }
    },
    "envVar": {
      "type": "object",
      "required": ["name", "type", "label"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Env-var name"
        },
        "type": {
          "type": "string",
          "enum": ["text", "secret"],
          "description": "secret → masked + SecretStorage; text → Configure UI → .env"
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable label for the collection UI"
        },
        "derivedFrom": {
          "type": "string",
          "description": "Derived from another known value (e.g. connect-commerce backend config)"
        },
        "providedBy": {
          "type": "string",
          "description": "Provided by another deployable that declares it in providesEnvVars"
        }
      }
    },
    "gitHubSource": {
      "type": "object",
      "required": ["owner", "repo", "branch"],
      "properties": {
        "owner": {
          "type": "string",
          "minLength": 1,
          "description": "GitHub owner/organization"
        },
        "repo": {
          "type": "string",
          "minLength": 1,
          "description": "GitHub repository name"
        },
        "branch": {
          "type": "string",
          "minLength": 1,
          "description": "Branch to fetch from"
        }
      }
    }
  }
}
