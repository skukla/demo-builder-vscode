{
  "$schema": "./stacks.schema.json",
  "version": "1.0.0",
  "addonDefinitions": {
    "adobe-commerce-aco": {
      "name": "Adobe Commerce Optimizer",
      "description": "Catalog optimization service for enhanced product discovery"
    },
    "adobe-commerce-b2b": {
      "name": "B2B Commerce",
      "description": "Company management, quotes, purchase orders, and requisition lists",
      "source": {
        "owner": "adobe-commerce",
        "repo": "boilerplate-b2b-template",
        "branch": "main"
      }
    }
  },
  "stacks": [
    {
      "id": "headless-paas",
      "name": "Headless + PaaS",
      "description": "NextJS storefront with API Mesh and Commerce PaaS",
      "icon": "nextjs",
      "frontend": "headless",
      "backend": "adobe-commerce-paas",
      "dependencies": ["headless-commerce-mesh"],
      "optionalAddons": [],
      "features": ["Server-side rendering", "API Mesh integration", "Full customization"]
    },
    {
      "id": "headless-accs",
      "name": "Headless + ACCS",
      "description": "NextJS storefront with API Mesh and Commerce ACCS",
      "icon": "nextjs",
      "frontend": "headless",
      "backend": "adobe-commerce-accs",
      "dependencies": ["headless-commerce-mesh"],
      "optionalAddons": [],
      "features": ["Server-side rendering", "API Mesh integration", "Managed backend"]
    },
    {
      "id": "eds-paas",
      "name": "Edge Delivery + PaaS",
      "description": "EDS storefront with Commerce Drop-ins and PaaS",
      "icon": "eds",
      "frontend": "eds-storefront",
      "backend": "adobe-commerce-paas",
      "dependencies": ["eds-commerce-mesh"],
      "optionalAddons": [
        { "id": "adobe-commerce-aco" },
        { "id": "adobe-commerce-b2b" }
      ],
      "features": ["Ultra-fast delivery", "DA.live content", "Self-managed backend"],
      "requiresGitHub": true,
      "requiresDaLive": true
    },
    {
      "id": "eds-accs",
      "name": "Edge Delivery + ACCS",
      "description": "EDS storefront with Commerce Drop-ins and ACCS",
      "icon": "eds",
      "frontend": "eds-storefront",
      "backend": "adobe-commerce-accs",
      "dependencies": ["eds-accs-mesh"],
      "optionalAddons": [
        { "id": "adobe-commerce-aco" },
        { "id": "adobe-commerce-b2b" }
      ],
      "features": ["Ultra-fast delivery", "DA.live content", "Managed backend"],
      "requiresGitHub": true,
      "requiresDaLive": true
    }
  ]
}
