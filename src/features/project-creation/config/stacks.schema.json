{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Demo Builder Stacks Schema",
  "description": "Schema for defining stacks (frontend + backend architecture combinations)",
  "type": "object",
  "required": ["version", "stacks"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Schema version (e.g., '1.0.0')"
    },
    "addonDefinitions": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/addonDefinition"
      },
      "description": "Addon display metadata and source configuration keyed by addon ID"
    },
    "stacks": {
      "type": "array",
      "description": "Array of available stacks",
      "items": {
        "$ref": "#/definitions/stack"
      },
      "minItems": 1
    }
  },
  "definitions": {
    "addonDefinition": {
      "type": "object",
      "required": ["name", "description"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable name for the addon"
        },
        "description": {
          "type": "string",
          "description": "Short description for UI display"
        },
        "source": {
          "type": "object",
          "required": ["owner", "repo", "branch"],
          "properties": {
            "owner": {
              "type": "string",
              "minLength": 1,
              "description": "GitHub owner/organization"
            },
            "repo": {
              "type": "string",
              "minLength": 1,
              "description": "GitHub repository name"
            },
            "branch": {
              "type": "string",
              "minLength": 1,
              "description": "Branch to fetch from"
            }
          },
          "additionalProperties": false,
          "description": "Source repository for content-fetching addons"
        }
      }
    },
    "stack": {
      "type": "object",
      "required": ["id", "name", "description", "frontend", "backend", "dependencies"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "description": "Unique identifier for the stack (lowercase, hyphen-separated)"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Display name for the stack"
        },
        "description": {
          "type": "string",
          "description": "Description of the stack architecture"
        },
        "icon": {
          "type": "string",
          "description": "Icon identifier for the stack"
        },
        "frontend": {
          "type": "string",
          "description": "Frontend component ID from components.json"
        },
        "backend": {
          "type": "string",
          "description": "Backend component ID from components.json"
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Array of dependency component IDs from components.json"
        },
        "optionalAddons": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id"],
            "properties": {
              "id": {
                "type": "string",
                "description": "Addon component ID from components.json"
              },
              "default": {
                "type": "boolean",
                "description": "Whether this addon should be pre-selected (default: false)"
              }
            }
          },
          "description": "Array of optional addons available for this stack"
        },
        "features": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Feature highlights for UI display"
        },
        "requiresGitHub": {
          "type": "boolean",
          "description": "Whether this stack requires GitHub OAuth authentication"
        },
        "requiresDaLive": {
          "type": "boolean",
          "description": "Whether this stack requires DA.live access"
        }
      }
    }
  }
}
