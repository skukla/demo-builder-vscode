{
  "version": "1.0.0",
  "featurePacks": [
    {
      "id": "b2b-commerce",
      "name": "B2B Commerce",
      "description": "Company management, quotes, purchase orders, requisition lists, and company switcher",
      "source": {
        "owner": "hlxsites",
        "repo": "aem-boilerplate-commerce",
        "branch": "b2b"
      },
      "stackTypes": ["eds-storefront"],
      "configFlags": {
        "commerce-b2b-enabled": true,
        "commerce-companies-enabled": true
      },
      "blocks": {
        "install": true,
        "sourceDir": "blocks"
      },
      "initializers": {
        "install": true,
        "sourceDir": "scripts/initializers",
        "files": [
          "company.js",
          "company-switcher.js",
          "purchase-order.js",
          "quick-order.js",
          "quote-management.js",
          "requisition-list.js"
        ]
      },
      "dependencies": {
        "@dropins/storefront-company-management": "~1.2.0",
        "@dropins/storefront-company-switcher": "~1.1.1",
        "@dropins/storefront-purchase-order": "~1.1.1",
        "@dropins/storefront-quick-order": "~1.0.1",
        "@dropins/storefront-quote-management": "~1.1.2",
        "@dropins/storefront-requisition-list": "~1.3.0"
      }
    }
  ]
}
