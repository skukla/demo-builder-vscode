{
  "$schema": "./demo-packages.schema.json",
  "version": "1.0.0",
  "packages": [
    {
      "id": "isle5",
      "name": "Isle5",
      "description": "Commerce demo with Isle5 branding and custom EDS blocks",
      "icon": "isle5",
      "featured": true,
      "requiresMesh": false,
      "addons": {
        "adobe-commerce-aco": "excluded"
      },
      "featurePacks": {
        "b2b-commerce": "optional"
      },
      "configDefaults": {
        "ADOBE_COMMERCE_WEBSITE_CODE": "base",
        "ADOBE_COMMERCE_STORE_CODE": "main_website_store",
        "ADOBE_COMMERCE_STORE_VIEW_CODE": "default",
        "ACCS_WEBSITE_CODE": "base",
        "ACCS_STORE_CODE": "main_website_store",
        "ACCS_STORE_VIEW_CODE": "default"
      },
      "storefronts": {
        "eds-paas": {
          "name": "Isle5 EDS + PaaS",
          "description": "Edge Delivery Services storefront with Commerce PaaS backend",
          "icon": "eds",
          "featured": true,
          "tags": ["eds", "isle5", "paas"],
          "source": {
            "type": "git",
            "url": "https://github.com/stephen-garner-adobe/isle5",
            "branch": "main",
            "gitOptions": { "shallow": true }
          },
          "templateOwner": "stephen-garner-adobe",
          "templateRepo": "isle5",
          "contentSource": {
            "org": "stephen-garner-adobe",
            "site": "isle5",
            "indexPath": "/sitemap.json"
          },
          "contentPatches": ["nav-create-account-link"]
        },
        "eds-accs": {
          "name": "Isle5 EDS + ACCS",
          "description": "Edge Delivery Services storefront with Commerce Cloud Service backend",
          "icon": "eds",
          "featured": false,
          "tags": ["eds", "isle5", "accs"],
          "source": {
            "type": "git",
            "url": "https://github.com/stephen-garner-adobe/isle5",
            "branch": "main",
            "gitOptions": { "shallow": true }
          },
          "templateOwner": "stephen-garner-adobe",
          "templateRepo": "isle5",
          "contentSource": {
            "org": "stephen-garner-adobe",
            "site": "isle5",
            "indexPath": "/sitemap.json"
          },
          "contentPatches": ["nav-create-account-link"]
        }
      }
    },
